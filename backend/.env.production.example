# ============================================
# Guardian AI - 本番環境設定テンプレート
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.production.example .env

# アプリケーション
SECRET_KEY=          # 必須: openssl rand -hex 32 で生成
DEBUG=false

# データベース (docker-compose.production.yml で使用)
POSTGRES_USER=guardian_prod
POSTGRES_PASSWORD=   # 必須: 強いパスワードを設定
POSTGRES_DB=guardian_ai

# Redis
REDIS_PASSWORD=      # 必須: 強いパスワードを設定

# LINE Login
LINE_CHANNEL_ID=     # 必須: LINE Developers Console から取得
LINE_CHANNEL_SECRET= # 必須: LINE Developers Console から取得
LINE_REDIRECT_URI=https://api.guardian-ai.jp/api/v1/auth/line/callback

# Apple Sign-In
APPLE_TEAM_ID=       # Apple Developer Account Team ID
APPLE_BUNDLE_ID=com.guardianai.app

# Google Sign-In
GOOGLE_CLIENT_ID=    # Google Cloud Console から取得

# Firebase Cloud Messaging
FCM_CREDENTIALS_PATH=/app/credentials/firebase.json

# 地図API
MAPBOX_TOKEN=        # Mapbox から取得
GOOGLE_MAPS_API_KEY= # Google Cloud Console から取得

# GPSデバイス連携
BOT_WEBHOOK_SECRET=
MITSUNE_API_KEY=

# CORS (JSON配列形式)
CORS_ORIGINS=["https://guardian-ai.jp","https://admin.guardian-ai.jp"]

# Docker イメージタグ
IMAGE_TAG=latest

# ステージングデプロイ (GitHub Actions)
# STAGING_HOST=staging.guardian-ai.jp
# STAGING_SSH_KEY=<SSH秘密鍵>

# EAS Build (GitHub Actions)
# EXPO_TOKEN=<Expo アカウントトークン>
