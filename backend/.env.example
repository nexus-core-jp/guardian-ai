# アプリケーション
SECRET_KEY=your-secret-key-here
DEBUG=true

# データベース (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://guardian:guardian@localhost:5434/guardian_ai

# Redis
REDIS_URL=redis://localhost:6380/0

# LINE Login
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:8002/api/v1/auth/line/callback

# Firebase Cloud Messaging
FCM_CREDENTIALS_PATH=./firebase-credentials.json

# 地図API
MAPBOX_TOKEN=your-mapbox-token
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
